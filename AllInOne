UPdate(){

# اسم المستودع
REPO="blue24bluer/AllInOne"

# اسم الملف المراد التحقق منه
FILE_PATH="${PREFIX}/etc/B24B/blue24bluer/AllInOne/AllInOne"  # المسار المحلي للملف

# تحقق من وجود الملف المحلي
if [ ! -f "$FILE_PATH" ]; then
  echo "Local file does not exist"
  exit 1
fi

# احصل على تاريخ آخر تعديل للملف المحلي
LOCAL_MODIFIED_DATE=$(stat -c %Y "$FILE_PATH")

# احصل على تاريخ آخر تعديل للملف من GitHub
REMOTE_MODIFIED_DATE=$(curl -s "https://api.github.com/repos/$REPO/commits?path=$(basename $FILE_PATH)" | grep '"date":' | head -1 | sed -E 's/.*"([^"]+)".*/\1/')

# تحقق من الفشل في الحصول على التاريخ
if [ -z "$REMOTE_MODIFIED_DATE" ]; then
  echo "Failed to get last modified date of file from GitHub."
  exit 1
fi

# تحويل تاريخ التعديل على GitHub إلى timestamp
REMOTE_MODIFIED_TIMESTAMP=$(date -d "$REMOTE_MODIFIED_DATE" +%s)

# قارن بين تاريخي التعديل
if [ "$REMOTE_MODIFIED_TIMESTAMP" -gt "$LOCAL_MODIFIED_DATE" ]; then
  echo "You have to wait, there is a new update. It was modified in $REMOTE_MODIFIED_DATE"
  rm -rfd ${PREFIX}/etc/B24B/blue24bluer/AllInOne
  cd ${PREFIX}/etc/B24B/blue24bluer/
  curl -O https://raw.githubusercontent.com/blue24bluer/AllInOne/main/AllInOne
  bash AllInOne --start
else
  echo "The file on your device is up to date. It was last modified on $(date -d @$LOCAL_MODIFIED_DATE '+%Y-%m-%dT%H:%M:%S')"
fi


}
